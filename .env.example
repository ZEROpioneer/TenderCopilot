# ===========================================
# TenderCopilot 环境变量配置文件
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实配置值
# 3. .env 文件不会被上传到 Git
# ===========================================

# AI 提供商配置（二选一）
# -----------------------------------------
# 方案 1: 使用 Google Gemini（推荐，有免费额度）
GEMINI_API_KEY=your_gemini_api_key_here

# 方案 2: 使用 OpenAI（可选）
# OPENAI_API_KEY=your_openai_api_key_here

# 通知配置
# -----------------------------------------
# 企业微信机器人 Webhook URL
# 获取方式：企业微信 -> 群机器人 -> 添加机器人 -> 复制 Webhook 地址
WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 邮件通知密码（可选，如启用邮件通知需配置）
EMAIL_PASSWORD=your_email_password_here

# 其他服务 Token（可选）
# -----------------------------------------
# Server酱/PushPlus 等服务的 Token（如启用个人微信通知需配置）
WECHAT_PERSONAL_TOKEN=your_token_here

# 钉钉机器人（如启用钉钉通知需配置）
DINGTALK_WEBHOOK=your_dingtalk_webhook_here
DINGTALK_SECRET=your_dingtalk_secret_here

# ===========================================
# 配置说明
# ===========================================
# 1. 必需配置（至少配置一项）：
#    - GEMINI_API_KEY 或 OPENAI_API_KEY（AI分析）
#    - WECHAT_WORK_WEBHOOK（企业微信通知）
#
# 2. 可选配置：
#    - EMAIL_PASSWORD（邮件通知）
#    - WECHAT_PERSONAL_TOKEN（个人微信通知）
#    - DINGTALK_*（钉钉通知）
#
# 3. 如果某项服务未启用，对应的环境变量可以留空
